generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Enum_Role {
  ADMIN
  USER
}

model User {
  id    String @id
  name  String
  email String @unique
  image String?
  deleted Boolean @default(false)
  enabled Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role Enum_Role @default(USER)

  @@index([email])
}